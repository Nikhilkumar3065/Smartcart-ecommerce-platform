# Example configuration values for transactional email provider
# Rename this file to .env and set the values for your environment.

# MAIL_PROVIDER can be: gmail, smtp, sendgrid, mailgun
MAIL_PROVIDER=sendgrid

# General SMTP settings
MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=apikey
MAIL_PASSWORD=YOUR_SENDGRID_API_KEY
MAIL_DEFAULT_SENDER="SmartCart <no-reply@yourdomain.com>"

# Database settings still use config.py values, but for better security you can also put them here and load from env.
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=db password
# DB_NAME=db name
